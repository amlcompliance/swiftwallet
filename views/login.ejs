<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>SwiftWallet Login</title>
    <style>
      body { font-family: Arial, sans-serif; background:#f3f6fb; margin:0; padding:40px; }
      .card { max-width:420px; margin:0 auto; background:#fff; padding:30px; border-radius:12px; box-shadow:0 6px 24px rgba(0,0,0,0.08); }
      input, button { width:100%; padding:12px; margin-top:10px; border-radius:8px; border:1px solid #cfd8e3; }
      button { background:#0b6cff; color:#fff; border:none; cursor:pointer; }
      .link { display:block; margin-top:12px; color:#0b6cff; text-decoration:none; }
      .error { color:#c0392b; margin-top:8px; }
    </style>
  </head>
  <body>
    <div class="card">
      <h2>SwiftWallet Login</h2>
      <form method="post" action="/login">
        <input name="email" placeholder="Email" required />
        <input name="password" type="password" placeholder="Password" required />
        <button type="submit">Sign In</button>
      </form>
      <% if (error) { %><div class="error"><%= error %></div><% } %>
      <a class="link" href="/forgot-password">Forgot password?</a>
      <a class="link" href="/register">Create account</a>
      <a class="link" href="/compliance">Compliance info</a>
    </div>
  </body>
</html>
